msgid "plugins.generic.aiReviewer.displayName"
msgstr "AI Reviewer"

msgid "plugins.generic.aiReviewer.description"
msgstr "Plugin, který pomáhá při kontrole rukopisu pomocí AI."

msgid "plugins.generic.aiReviewer.settings.apiKey"
msgstr "Klíč API"

msgid "plugins.generic.aiReviewer.settings.apiKey.description"
msgstr "Zadejte svůj tajný klíč API pro vybraný model AI."

msgid "plugins.generic.aiReviewer.settings.aiModel"
msgstr "Model AI"

msgid "plugins.generic.aiReviewer.button.description"
msgstr "Automaticky vygenerovat recenzi tohoto rukopisu pomocí umělé inteligence."

msgid "plugins.generic.aiReviewer.button.generate"
msgstr "Generování AI Review"

msgid "plugins.generic.aiReviewer.button.alert"
msgstr "Tato funkce je v současné době zástupným symbolem pro budoucí integraci AI. Již brzy!"

msgid "plugins.generic.aiReviewer.button.loading"
msgstr "Načítání AI Review... Může to trvat až 60 sekund."

msgid "plugins.generic.aiReviewer.button.saved"
msgstr "Recenze AI byla uložena jako soubor pro odeslání. Obnovte prosím tuto stránku, chcete-li ji zobrazit v mřížce Kontrolní soubory."

msgid "plugins.generic.aiReviewer.language"
msgstr "Výstupní jazyk"

msgid "plugins.generic.aiReviewer.settings.enableActivityLog"
msgstr "Zaznamenat generování kontroly AI v protokolu činností"


msgid "plugins.generic.aiReviewer.settings.customPrompt"
msgstr "Pokyny pro vlastní výzvu (volitelné)"

msgid "plugins.generic.aiReviewer.settings.customPrompt.description"
msgstr "Zadejte vlastní pokyny nebo konkrétní rubriku pro recenzenta AI. Pokud ponecháte prázdné, použije se výchozí 7bodový formát akademické recenze. Můžete specifikovat oblasti zaměření nebo konkrétní otázky, které chcete AI položit."

