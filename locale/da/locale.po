msgstr "AI-gennemgangen er blevet gemt som en indsendelsesfil. Opdater denne side for at se den i gitteret til gennemsynsfiler."

msgid "plugins.generic.aiReviewer.language"
msgstr "Output sprog"

msgid "plugins.generic.aiReviewer.settings.enableActivityLog"
msgstr "Log AI Review-generering i aktivitetslog"


msgid "plugins.generic.aiReviewer.settings.customPrompt"
msgstr "Brugerdefinerede vejledninger (valgfrit)"

msgid "plugins.generic.aiReviewer.settings.customPrompt.description"
msgstr "Indtast tilpassede instruktioner eller en specifik rubrik for AI-anmelderen. Hvis det efterlades tomt, vil standard 7-punkts akademisk anmeldelsesformat blive brugt. Du kan angive fokusområder eller specifikke spørgsmål at stille AI'en."

