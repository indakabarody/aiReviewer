msgid "plugins.generic.aiReviewer.displayName"
msgstr "AI Reviewer"

msgid "plugins.generic.aiReviewer.description"
msgstr "A plugin to assist manuscript review using AI."

msgid "plugins.generic.aiReviewer.settings.apiKey"
msgstr "API Key"

msgid "plugins.generic.aiReviewer.settings.apiKey.description"
msgstr "Enter your secret API key for the selected AI model."

msgid "plugins.generic.aiReviewer.settings.aiModel"
msgstr "AI Model"

msgid "plugins.generic.aiReviewer.button.description"
msgstr "Automatically generate a review for this manuscript using artificial intelligence."

msgid "plugins.generic.aiReviewer.button.generate"
msgstr "Generate AI Review"

msgid "plugins.generic.aiReviewer.button.alert"
msgstr "This feature is currently a placeholder for the future AI integration. Coming soon!"

msgid "plugins.generic.aiReviewer.button.loading"
msgstr "Loading AI Review... This may take up to 60 seconds."


msgid "plugins.generic.aiReviewer.button.saved"
msgstr "The AI Review has been saved as a Submission File. Please refresh this page to view it in the Review Files grid."


msgid "plugins.generic.aiReviewer.language"
msgstr "Output Language"
msgid "plugins.generic.aiReviewer.settings.enableActivityLog"
msgstr "Log AI Review generation in Activity Log"


msgid "plugins.generic.aiReviewer.settings.customPrompt"
msgstr "Custom Prompt Instructions (Optional)"

msgid "plugins.generic.aiReviewer.settings.customPrompt.description"
msgstr "Enter custom instructions or a specific rubric for the AI Reviewer. If left blank, the default 7-point academic review format will be used. You can specify focus areas or specific questions to ask the AI."
