msgstr "AI մոդել"

msgid "plugins.generic.aiReviewer.button.description"
msgstr "Արհեստական ​​ինտելեկտի միջոցով ավտոմատ կերպով ստեղծեք այս ձեռագրի կարծիքը:"

msgid "plugins.generic.aiReviewer.button.generate"
msgstr "Ստեղծեք AI վերանայում"

msgid "plugins.generic.aiReviewer.button.alert"
msgstr "Այս հատկությունը ներկայումս հանդիսանում է ապագա AI ինտեգրման տեղապահ: Շուտով!"

msgid "plugins.generic.aiReviewer.button.loading"
