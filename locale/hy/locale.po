msgid "plugins.generic.aiReviewer.button.saved"
msgstr "AI Review-ը պահվել է որպես Ներկայացման Ֆայլ: Խնդրում ենք թարմացնել այս էջը՝ վերանայման ֆայլերի ցանցում դիտելու համար:"

msgid "plugins.generic.aiReviewer.language"
msgstr "Ելքի լեզու"

msgid "plugins.generic.aiReviewer.settings.enableActivityLog"
msgstr "Գրանցամատյան AI Review-ի ստեղծում Գործունեության մատյանում"


msgid "plugins.generic.aiReviewer.settings.customPrompt"
msgstr "Պատվերով արագ հրահանգներ (ըստ ցանկության)"

